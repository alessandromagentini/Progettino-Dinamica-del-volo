%----------------------------------------
%---------- ForceModels
%----------------------------------------

Create ForceModel JGM_deg0_ForceModel;
JGM_deg0_ForceModel.CentralBody = Earth;
JGM_deg0_ForceModel.PrimaryBodies = {Earth};
JGM_deg0_ForceModel.Drag = None;
JGM_deg0_ForceModel.SRP = Off;
JGM_deg0_ForceModel.RelativisticCorrection = Off;
JGM_deg0_ForceModel.ErrorControl = RSSStep;
JGM_deg0_ForceModel.GravityField.Earth.Degree = 0;
JGM_deg0_ForceModel.GravityField.Earth.Order = 0;
JGM_deg0_ForceModel.GravityField.Earth.StmLimit = 100;
JGM_deg0_ForceModel.GravityField.Earth.PotentialFile = 'JGM2.cof';
JGM_deg0_ForceModel.GravityField.Earth.TideModel = 'None';

Create ForceModel JGM_deg4_ForceModel;
JGM_deg4_ForceModel.CentralBody = Earth;
JGM_deg4_ForceModel.PrimaryBodies = {Earth};
JGM_deg4_ForceModel.Drag = None;
JGM_deg4_ForceModel.SRP = Off;
JGM_deg4_ForceModel.RelativisticCorrection = Off;
JGM_deg4_ForceModel.ErrorControl = RSSStep;
JGM_deg4_ForceModel.GravityField.Earth.Degree = 4;
JGM_deg4_ForceModel.GravityField.Earth.Order = 4;
JGM_deg4_ForceModel.GravityField.Earth.StmLimit = 100;
JGM_deg4_ForceModel.GravityField.Earth.PotentialFile = 'JGM2.cof';
JGM_deg4_ForceModel.GravityField.Earth.TideModel = 'None';

Create ForceModel Moon3body_Only_ForceModel;
Moon3body_Only_ForceModel.CentralBody = Earth;
Moon3body_Only_ForceModel.PrimaryBodies = {Earth};
Moon3body_Only_ForceModel.PointMasses = {Luna};
Moon3body_Only_ForceModel.Drag = None;
Moon3body_Only_ForceModel.SRP = Off;
Moon3body_Only_ForceModel.RelativisticCorrection = Off;
Moon3body_Only_ForceModel.ErrorControl = RSSStep;
Moon3body_Only_ForceModel.GravityField.Earth.Degree = 0;
Moon3body_Only_ForceModel.GravityField.Earth.Order = 0;
Moon3body_Only_ForceModel.GravityField.Earth.StmLimit = 100;

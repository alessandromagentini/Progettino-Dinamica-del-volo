JGM_deg70_Moon3body_ForceModel.GravityField.Earth.TideModel = 'None';

%----------------------------------------
%---------- Propagators
%----------------------------------------

Create Propagator JGM_deg0;
JGM_deg0.FM = JGM_deg0_ForceModel;
JGM_deg0.Type = RungeKutta89;
JGM_deg0.InitialStepSize = 60;
JGM_deg0.Accuracy = 9.999999999999999e-12;
JGM_deg0.MinStep = 0.001;
JGM_deg0.MaxStep = 2700;
JGM_deg0.MaxStepAttempts = 50;
JGM_deg0.StopIfAccuracyIsViolated = true;

Create Propagator JGM_deg4;
JGM_deg4.FM = JGM_deg4_ForceModel;
JGM_deg4.Type = RungeKutta89;
JGM_deg4.InitialStepSize = 60;
JGM_deg4.Accuracy = 9.999999999999999e-12;
JGM_deg4.MinStep = 0.001;
JGM_deg4.MaxStep = 2700;
JGM_deg4.MaxStepAttempts = 50;
JGM_deg4.StopIfAccuracyIsViolated = true;

Create Propagator Moon3body_Only;
Moon3body_Only.FM = Moon3body_Only_ForceModel;

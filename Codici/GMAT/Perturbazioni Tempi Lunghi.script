Moon3body_Only.Accuracy = 9.999999999999999e-12;
Moon3body_Only.MinStep = 0.001;
Moon3body_Only.MaxStep = 2700;
Moon3body_Only.MaxStepAttempts = 50;
Moon3body_Only.StopIfAccuracyIsViolated = true;

Create Propagator JGM_deg70_Moon3body;

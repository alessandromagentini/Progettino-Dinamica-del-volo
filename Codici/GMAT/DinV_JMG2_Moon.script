only3body_ForceModel.GravityField.Earth.TideModel = 'None';

Create ForceModel deg4_ForceModel;
deg4_ForceModel.CentralBody = Earth;
deg4_ForceModel.PrimaryBodies = {Earth};
deg4_ForceModel.Drag = None;
deg4_ForceModel.SRP = Off;
deg4_ForceModel.RelativisticCorrection = Off;
deg4_ForceModel.ErrorControl = RSSStep;
deg4_ForceModel.GravityField.Earth.Degree = 4;
deg4_ForceModel.GravityField.Earth.Order = 4;
deg4_ForceModel.GravityField.Earth.StmLimit = 100;
deg4_ForceModel.GravityField.Earth.PotentialFile = 'JGM2.cof';
deg4_ForceModel.GravityField.Earth.TideModel = 'None';

%----------------------------------------
%---------- Propagators
%----------------------------------------

Create Propagator deg4_3body;
deg4_3body.FM = deg4_3body_ForceModel;
deg4_3body.Type = RungeKutta89;
deg4_3body.InitialStepSize = 60;
deg4_3body.Accuracy = 9.999999999999999e-12;
deg4_3body.MinStep = 0.001;
deg4_3body.MaxStep = 2700;
deg4_3body.MaxStepAttempts = 50;
deg4_3body.StopIfAccuracyIsViolated = true;

Create Propagator deg0;
deg0.FM = deg0_ForceModel;
deg0.Type = RungeKutta89;
deg0.InitialStepSize = 60;
deg0.Accuracy = 9.999999999999999e-12;
deg0.MinStep = 0.001;
deg0.MaxStep = 2700;
deg0.MaxStepAttempts = 50;
deg0.StopIfAccuracyIsViolated = true;

Create Propagator only3body;
only3body.FM = only3body_ForceModel;
only3body.Type = RungeKutta89;
only3body.InitialStepSize = 60;
only3body.Accuracy = 9.999999999999999e-12;
only3body.MinStep = 0.001;
only3body.MaxStep = 2700;
only3body.MaxStepAttempts = 50;
only3body.StopIfAccuracyIsViolated = true;

Create Propagator deg4;
deg4.FM = deg4_ForceModel;
deg4.Type = RungeKutta89;
deg4.InitialStepSize = 60;
deg4.Accuracy = 9.999999999999999e-12;
deg4.MinStep = 0.001;
deg4.MaxStep = 2700;
deg4.MaxStepAttempts = 50;
deg4.StopIfAccuracyIsViolated = true;

%----------------------------------------
%---------- EventLocators
%----------------------------------------

Create EclipseLocator DefaultEclipseLocator;
DefaultEclipseLocator.Spacecraft = SAT;
DefaultEclipseLocator.Filename = 'DefaultEclipseLocator.txt';
DefaultEclipseLocator.OccultingBodies = {Earth, Luna};
DefaultEclipseLocator.InputEpochFormat = 'TAIModJulian';
DefaultEclipseLocator.InitialEpoch = '21545';
DefaultEclipseLocator.StepSize = 10;
DefaultEclipseLocator.FinalEpoch = '21545.138';
DefaultEclipseLocator.UseLightTimeDelay = true;
DefaultEclipseLocator.UseStellarAberration = true;
DefaultEclipseLocator.WriteReport = true;
DefaultEclipseLocator.RunMode = Automatic;
DefaultEclipseLocator.UseEntireInterval = true;
DefaultEclipseLocator.EclipseTypes = {'Umbra', 'Penumbra', 'Antumbra'};

%----------------------------------------
%---------- Solvers
%----------------------------------------

Create DifferentialCorrector DefaultDC;
DefaultDC.ShowProgress = true;
DefaultDC.ReportStyle = Normal;
DefaultDC.ReportFile = 'DifferentialCorrectorDefaultDC.data';
DefaultDC.MaximumIterations = 25;
DefaultDC.DerivativeMethod = ForwardDifference;
DefaultDC.Algorithm = NewtonRaphson;


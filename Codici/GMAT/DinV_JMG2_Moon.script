%----------------------------------------
%---------- Mission Sequence
%----------------------------------------

BeginMissionSequence;
Propagate '3h' deg4_3body(SAT) {SAT.ElapsedSecs = 10800, OrbitColor = [253 37 32]};
Propagate '6h' deg4_3body(SAT) {SAT.ElapsedSecs = 10800, OrbitColor = [3 252 53]};
Propagate '9h' deg4_3body(SAT) {SAT.ElapsedSecs = 10800, OrbitColor = [33 55 252]};
Propagate '12h' deg4_3body(SAT) {SAT.ElapsedSecs = 10800, OrbitColor = [34 235 251]};
PenUp DefaultOrbitView;
Propagate deg0(sat2_d0) only3body(sat3_3b) deg4(sat4_d4) {sat2_d0.ElapsedDays = 15, sat3_3b.ElapsedDays = 15, sat4_d4.ElapsedDays = 15};

%----------------------------------------
%---------- ForceModels
%----------------------------------------

Create ForceModel deg4_3body_ForceModel;
deg4_3body_ForceModel.CentralBody = Earth;
deg4_3body_ForceModel.PrimaryBodies = {Earth};
deg4_3body_ForceModel.PointMasses = {Luna};
deg4_3body_ForceModel.Drag = None;
deg4_3body_ForceModel.SRP = Off;
deg4_3body_ForceModel.RelativisticCorrection = Off;
deg4_3body_ForceModel.ErrorControl = RSSStep;
deg4_3body_ForceModel.GravityField.Earth.Degree = 4;
deg4_3body_ForceModel.GravityField.Earth.Order = 4;
deg4_3body_ForceModel.GravityField.Earth.StmLimit = 100;
deg4_3body_ForceModel.GravityField.Earth.PotentialFile = 'JGM2.cof';
deg4_3body_ForceModel.GravityField.Earth.TideModel = 'None';

Create ForceModel deg0_ForceModel;
deg0_ForceModel.CentralBody = Earth;
deg0_ForceModel.PrimaryBodies = {Earth};
deg0_ForceModel.Drag = None;
deg0_ForceModel.SRP = Off;
deg0_ForceModel.RelativisticCorrection = Off;
deg0_ForceModel.ErrorControl = RSSStep;
deg0_ForceModel.GravityField.Earth.Degree = 0;
deg0_ForceModel.GravityField.Earth.Order = 0;
